{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://otel-poc.local/schemas/grafana-dashboard-provider.schema.json",
  "title": "Grafana Dashboard Provider Provisioning",
  "type": "object",
  "required": [
    "apiVersion",
    "providers"
  ],
  "properties": {
    "apiVersion": {
      "type": "integer",
      "const": 1
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "options"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "orgId": {
            "type": "integer",
            "minimum": 1
          },
          "folder": {
            "type": "string"
          },
          "folderUid": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "const": "file"
          },
          "disableDeletion": {
            "type": "boolean"
          },
          "allowUiUpdates": {
            "type": "boolean"
          },
          "updateIntervalSeconds": {
            "type": "integer",
            "minimum": 1
          },
          "options": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "minLength": 1
              },
              "foldersFromFilesStructure": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}